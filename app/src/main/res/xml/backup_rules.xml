<?xml version="1.0" encoding="utf-8"?>
<!--
  Auto Backup rules (API <= 30, android:fullBackupContent). Exclude the credentials
  DataStore (wspr_settings.preferences_pb, which holds the QRZ username/password and
  the operator/searched callsigns) and the disposable Room spot cache (wspr.db) from
  cloud Auto Backup so reusable QRZ.com credentials never leave the device.
-->
<full-backup-content>
    <exclude domain="file" path="datastore/wspr_settings.preferences_pb" />
    <exclude domain="database" path="wspr.db" />
    <exclude domain="database" path="wspr.db-shm" />
    <exclude domain="database" path="wspr.db-wal" />
</full-backup-content>
