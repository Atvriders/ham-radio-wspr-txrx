<?xml version="1.0" encoding="utf-8"?>
<!--
  Data extraction rules (API 31+, android:dataExtractionRules). Exclude the credentials
  DataStore (wspr_settings.preferences_pb) and the disposable Room spot cache (wspr.db)
  from BOTH cloud backup AND device-to-device transfer, so reusable QRZ.com credentials
  and the operator/searched callsigns never leave the device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="datastore/wspr_settings.preferences_pb" />
        <exclude domain="database" path="wspr.db" />
        <exclude domain="database" path="wspr.db-shm" />
        <exclude domain="database" path="wspr.db-wal" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="datastore/wspr_settings.preferences_pb" />
        <exclude domain="database" path="wspr.db" />
        <exclude domain="database" path="wspr.db-shm" />
        <exclude domain="database" path="wspr.db-wal" />
    </device-transfer>
</data-extraction-rules>
